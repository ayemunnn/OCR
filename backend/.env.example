# Optional database override. Leave unset to use backend/papersleuth.db locally.
# DATABASE_URL=sqlite:///./papersleuth.db
# Optional PostgreSQL development URL:
# DATABASE_URL=postgresql+psycopg2://<username>:<password>@localhost:5432/<database_name>
APP_NAME=PaperSleuth
APP_ENV=development
APP_DEBUG=false
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]
CORS_ORIGINS=
FRONTEND_URL=http://127.0.0.1:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
# Production Google redirect URI:
# GOOGLE_REDIRECT_URI=https://papersleuth-api.blueplant-9aa4530b.canadacentral.azurecontainerapps.io/auth/google/callback
# Optional Hugging Face token for LLM cleanup/extraction.
# Leave blank to run OCR-only mode.
HF_API_KEY=
HF_MODEL_NAME=google/gemma-3-27b-it
STORAGE_PROVIDER=local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=papersleuth-documents
